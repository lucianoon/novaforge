# Nova Forge environment configuration
# Copy this file to .env and replace the placeholder values.

# Required for protected admin API routes. Use a long random value.
ADMIN_KEY=replace-with-a-long-random-admin-token

# Optional database configuration, depending on your deployment/storage setup.
DATABASE_URL=postgresql://user:password@localhost:5432/novaforge

# Optional email/API integrations.
SENDGRID_API_KEY=
